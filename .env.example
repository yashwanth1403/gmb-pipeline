# ============================================================
# AGENT 1 — GMB Lead Scraper (SerpAPI)
# ============================================================
SERPAPI_KEY=your_serpapi_key_here

# Search query (location baked into query, e.g. "used car dealers in Madhapur")
GMB_QUERY=used car dealers in Madhapur, Hyderabad, India

# OPTIONAL: city for SerpAPI radius filter. Leave blank if geo is in the query.
# GMB_LOCATION=Mumbai, India

# Max results per scrape (SerpAPI returns 20 per page)
SCRAPE_MAX_RESULTS=40

# Public URL where generated sites will live (used by Agent 3 outreach)
SITE_BASE_URL=http://localhost:8000/sites


# ============================================================
# AGENT 2 — Site Builder (OpenAI + React + Netlify)
# ============================================================

# OpenAI API key (used for marketing copy + logo generation)
OPENAI_API_KEY=sk-...
OPENAI_LOGO_MODEL=gpt-4o-mini

# Skip LLM calls entirely (use embedded llm content or defaults)
# USE_LLM=true

# Skip OpenAI logo generation (use initial-based fallback)
# GENERATE_LOGO=true

# Set to true to deploy to Netlify after build
DEPLOY_TO_NETLIFY=false

# Netlify Personal Access Token (https://app.netlify.com/user/applications/personal-access-tokens)
NETLIFY_AUTH_TOKEN=your_netlify_token


# ============================================================
# AGENT 3 — Outreach (Email + WhatsApp via Baileys)
# ============================================================

# --- WhatsApp (Baileys, QR-scan once) ---
# Flip this on ONLY after you've scanned the QR at least once.
# First-time setup (run from project root):
#   cd whatsapp-sender/sender && npm install && node sender.js setup
SEND_WHATSAPP=false

# Run Agent 3 inside scripts/run_pipeline.py after a build?
# true  → scrape → build → deploy → outreach (all in one shot)
# false → only scrape → build → deploy (current behavior)
RUN_AGENT3_AUTOMATIC=false

# Cap how many businesses Agent 3 will message per run (avoid blasting).
WA_DAILY_LIMIT=20

# Delay between the intro message and the link message (seconds).
WA_MSG_DELAY_SEC=3

# --- Email (not implemented yet) ---
# SEND_EMAIL=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password

# --- Meta WhatsApp Cloud API (alternative, not used by Agent 3 yet) ---
# WA_API_TOKEN=your_meta_whatsapp_token
# WA_PHONE_ID=your_phone_id